{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "README Timeline",
  "type": "object",
  "required": ["items"],
  "properties": {
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["date", "icon", "title", "url"],
        "properties": {
          "date": {
            "type": "string",
            "pattern": "^\\d{4}-\\d{2}$",
            "description": "YYYY-MM 형식. 예: 2024-03"
          },
          "icon": {
            "type": "string",
            "description": "simple-icons slug. 예: flutter, react, wordpress"
          },
          "title": {
            "type": "string",
            "maxLength": 20,
            "description": "프로젝트/경력명. 너무 길면 핀 안에서 잘림"
          },
          "url": {
            "type": "string",
            "format": "uri",
            "description": "클릭(이미지 전체) 시 이동할 링크는 별도지만, 항목별 상세 링크로 향후 확장 가능"
          },
          "color": {
            "type": "string",
            "pattern": "^#[0-9a-fA-F]{6}$",
            "description": "선택사항. 미지정 시 simple-icons 공식 브랜드 색상이 자동 적용됨. 예: #02569B"
          }
        }
      }
    }
  }
}
